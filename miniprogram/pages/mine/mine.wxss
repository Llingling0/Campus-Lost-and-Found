/* 我的页面样式 */
.container {
  padding: 20rpx;
  background: #f5f6f8;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.sub {
  font-size: 28rpx;
  color: #666;
  margin-top: 12rpx;
  line-height: 1.6;
}

/* 输入框 */
input {
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 14rpx;
  margin: 10rpx 0;
  font-size: 28rpx;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

button[size="mini"] {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 6rpx;
}

/* 发布列表 */
.post-item {
  padding: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.post-status {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.status-draft {
  background: #eee;
  color: #666;
}

.status-pending {
  background: #fff7e6;
  color: #ff9800;
}

.status-published {
  background: #e6f7e6;
  color: #4caf50;
}

.status-rejected {
  background: #fef0f0;
  color: #f44336;
}

.post-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #fff;
}

.user-details {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
}

.user-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
