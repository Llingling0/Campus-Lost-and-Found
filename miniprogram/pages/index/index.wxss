/* 首页样式 */
.container {
  padding: 20rpx;
  background: #f5f6f8;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.card-title .icon {
  font-size: 36rpx;
}

/* 搜索卡片 */
.search-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  color: #333; /* 输入文字颜色 */
}

.search-box input::placeholder {
  color: #999; /* 占位符颜色 */
}

.btn-search {
  background: #0b6cff;
  color: #fff;
  border: none;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
}

.type-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.type-tabs .tab {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  font-size: 26rpx;
  padding: 12rpx 0;
}

.type-tabs .tab.active {
  background: rgba(255, 255, 255, 0.4);
  font-weight: 600;
}

/* 公告卡片 */
.announcement-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.announcement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announcement-time {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 列表卡片 */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.post-item:active {
  background: #f0f0f0;
}

.post-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f5f5f5;
  position: relative;
  flex-shrink: 0;
}

.post-image image {
  width: 100%;
  height: 100%;
}

.post-image .no-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ccc;
}

.type-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  color: #fff;
}

.type-tag.lost {
  background: #ff9800;
}

.type-tag.found {
  background: #4caf50;
}

.post-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.post-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.post-desc {
  font-size: 26rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #666;
  font-size: 28rpx;
}

/* 分页控件 */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #eee;
}

.page-btn {
  background: #f5f5f5;
  color: #666;
  border: 1rpx solid #ddd;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 6rpx;
  min-width: 140rpx;
}

.page-btn:not([disabled]):active {
  background: #e0e0e0;
}

.page-btn.disabled {
  opacity: 0.5;
  background: #f5f5f5;
}

.page-numbers {
  display: flex;
  gap: 12rpx;
}

.page-number {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.page-number:active {
  background: #e0e0e0;
}

.page-number.active {
  background: #0b6cff;
  color: #fff;
  font-weight: 600;
}

.page-info {
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}
