<view class="container">
  <!-- 搜索区域 -->
  <view class="card search-card">
    <view class="search-box">
      <input placeholder="搜索物品名称、描述..." value="{{keyword}}" bindinput="onKeywordInput" />
      <button size="mini" class="btn-search" bindtap="onSearch">搜索</button>
    </view>
    <view class="type-tabs">
      <button 
        class="tab {{postType===0?'active':''}}" 
        data-type="0" 
        bindtap="onTypeChange">全部</button>
      <button 
        class="tab {{postType===1?'active':''}}" 
        data-type="1" 
        bindtap="onTypeChange">失物</button>
      <button 
        class="tab {{postType===2?'active':''}}" 
        data-type="2" 
        bindtap="onTypeChange">招领</button>
    </view>
  </view>

  <!-- 校园公告 -->
  <view class="card announcement-card">
    <view class="card-title">
      <text class="icon">📢</text>
      <text>校园公告</text>
    </view>
    <view wx:if="{{announcements && announcements.length > 0}}" class="announcement-list">
      <view wx:for="{{announcements}}" wx:key="id" class="announcement-item">
        <text class="announcement-title">{{item.title}}</text>
        <text class="announcement-time">{{item.created_at}}</text>
      </view>
    </view>
    <view wx:else class="empty-tip">暂无公告</view>
  </view>

  <!-- 信息列表 -->
  <view class="card post-list-card">
    <view class="card-title">
      <text class="icon">📋</text>
      <text>最新信息</text>
    </view>
    
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    
    <view wx:elif="{{list.length > 0}}" class="post-list">
      <view 
        wx:for="{{list}}" 
        wx:key="post_no" 
        class="post-item" 
        data-id="{{item.id}}" 
        bindtap="goDetail">
        
        <view class="post-image">
          <image wx:if="{{item.images && item.images[0]}}" src="{{item.images[0].imgUrl}}" mode="aspectFill" />
          <view wx:else class="no-image">无图</view>
          <view class="type-tag {{item.post_type===1?'lost':'found'}}">
            {{item.post_type===1?'失物':'招领'}}
          </view>
        </view>
        
        <view class="post-info">
          <view class="post-title">{{item.title}}</view>
          <view class="post-meta">
            <text class="location">📍 {{item.occur_location || '未知地点'}}</text>
            <text class="time">🕐 {{item.created_at}}</text>
          </view>
          <view class="post-desc">{{item.detail || '暂无描述'}}</view>
        </view>
      </view>
      
      <!-- 分页控件 -->
      <view class="pagination" wx:if="{{total > 0}}">
        <button 
          class="page-btn {{pageNo === 1 ? 'disabled' : ''}}" 
          bindtap="onPrevPage" 
          disabled="{{pageNo === 1}}">上一页</button>
        
        <view class="page-numbers">
          <view 
            wx:for="{{5}}" 
            wx:key="*this" 
            wx:for-item="i"
            class="page-number {{pageNo === i + 1 ? 'active' : ''}}"
            data-page="{{i + 1}}"
            bindtap="onPageChange">
            {{i + 1}}
          </view>
        </view>
        
        <button 
          class="page-btn {{!hasMore ? 'disabled' : ''}}" 
          bindtap="onNextPage" 
          disabled="{{!hasMore}}">下一页</button>
      </view>
      
      <view class="page-info" wx:if="{{total > 0}}">
        共 {{total}} 条 · 第 {{pageNo}} 页
      </view>
    </view>
    
    <view wx:else class="empty-tip">暂无信息</view>
  </view>
</view>
