/* 发布页样式 */
.container {
  padding: 20rpx;
  background: #f5f6f8;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 类型选择 */
.type-selector {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.type-btn {
  flex: 1;
  background: #f7f8fa;
  color: #666;
  border: 2rpx solid transparent;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
}

.type-btn.active[data-type="1"] {
  background: #fff7e6;
  color: #ff9800;
  border-color: #ff9800;
}

.type-btn.active[data-type="2"] {
  background: #e6f7e6;
  color: #4caf50;
  border-color: #4caf50;
}

/* 表单元素 */
input {
  width: 100%;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 14rpx;
  margin: 10rpx 0;
  font-size: 28rpx;
  box-sizing: border-box;
}

textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 14rpx;
  margin: 10rpx 0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-item {
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 14rpx;
  margin: 10rpx 0;
  font-size: 28rpx;
  color: #666;
}

/* 图片上传 */
.image-uploader {
  margin-top: 20rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.add-image-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-draft {
  flex: 1;
  background: #f7f8fa;
  color: #666;
  border: none;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
}

.btn-submit {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  font-size: 28rpx;
  padding: 20rpx 0;
  border-radius: 8rpx;
}

.btn-submit:active {
  opacity: 0.8;
}

/* 提示信息 */
.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
