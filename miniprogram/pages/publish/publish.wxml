<view class="container">
  <view class="card">
    <view class="title">{{editingId ? '编辑信息' : '发布信息'}}</view>
    
    <!-- 类型选择 -->
    <view class="type-selector">
      <button 
        class="type-btn {{form.postType===1?'active':''}}" 
        data-type="1" 
        bindtap="onType">失物</button>
      <button 
        class="type-btn {{form.postType===2?'active':''}}" 
        data-type="2" 
        bindtap="onType">招领</button>
    </view>

    <!-- 基本信息 -->
    <input placeholder="物品名称*" data-key="title" bindinput="bindField" value="{{form.title}}" />
    
    <!-- 分类选择 -->
    <picker range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategory">
      <view class="picker-item">
        选择分类：{{categories[categoryIndex] ? categories[categoryIndex].name : '请选择'}}
      </view>
    </picker>
    
    <input placeholder="时间 (例：2026-03-27 10:00)" data-key="occurTime" bindinput="bindField" value="{{form.occurTime}}" />
    <input placeholder="地点 (例：教学楼 A 栋)" data-key="occurLocation" bindinput="bindField" value="{{form.occurLocation}}" />
    
    <!-- 详细描述 -->
    <textarea placeholder="详细描述物品特征，如颜色、品牌、特殊标识等" data-key="detail" bindinput="bindField" value="{{form.detail}}" />
    
    <!-- 联系方式（招领必填） -->
    <input wx:if="{{form.postType===2}}" placeholder="联系方式（仅管理员和认领人可见）" data-key="contactInfo" bindinput="bindField" value="{{form.contactInfo}}" />
    
    <!-- 悬赏金额（失物可选） -->
    <input wx:if="{{form.postType===1}}" placeholder="悬赏金额（可选）" type="digit" data-key="rewardAmount" bindinput="bindField" value="{{form.rewardAmount}}" />
    
    <!-- 存放地点（招领必填） -->
    <input wx:if="{{form.postType===2}}" placeholder="存放地点（必填）" data-key="depositLocation" bindinput="bindField" value="{{form.depositLocation}}" />
    
    <!-- 图片上传 -->
    <view class="image-uploader">
      <view class="tip">上传图片（最多 5 张）</view>
      <view class="image-list" wx:if="{{form.images && form.images.length > 0}}">
        <view wx:for="{{form.images}}" wx:key="*this" class="image-item">
          <image src="{{item}}" mode="aspectFill" />
          <view class="delete-btn" catchtap="deleteImage" data-index="{{index}}">×</view>
        </view>
      </view>
      <view wx:if="{{!form.images || form.images.length < 5}}" class="add-image-btn" bindtap="pickImage">+</view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-row">
      <button class="btn-draft" data-draft="1" bindtap="submit">保存草稿</button>
      <button class="btn-submit" data-draft="0" bindtap="submit">{{editingId ? '提交审核' : '立即发布'}}</button>
    </view>
    
    <view class="tip" style="margin-top: 20rpx; text-align: center;">
      {{editingId ? '编辑后需重新提交审核' : '发布后请等待管理员审核'}}
    </view>
  </view>
</view>
