/* 消息页面样式 */
.container {
  padding: 20rpx;
  background: #f5f6f8;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.sub {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.5;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.read-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #eee;
  color: #666;
  font-size: 22rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.unread-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background: #0b6cff;
  color: #fff;
  font-size: 22rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.btn-mark-all {
  font-size: 26rpx;
  color: #0b6cff;
  background: none;
  border: none;
  padding: 12rpx 24rpx;
}
